# Local .terraform directories
**/.terraform/

# Terraform state
*.tfstate
*.tfstate.*

# Exclude all .tfvars files (may contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore Terraform CLI config files
.terraformrc
terraform.rc

# Lock file (tùy chọn, xem giải thích bên dưới)
# .terraform.lock.hcl

# Plan files
*.tfplan
*.plan

# Sensitive variable files
secrets.auto.tfvars
terraform.auto.tfvars

